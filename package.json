{
	"name": "totopo",
	"version": "0.1.5",
	"description": "Secure AI Box — isolated dev environments for AI coding assistants",
	"type": "module",
	"bin": {
		"totopo": "./ai.sh"
	},
	"dependencies": {
		"@clack/prompts": "^1.1.0",
		"tsx": "^4.21.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.4.0",
		"js-yaml": "4.1.1",
		"typescript": "^5.9.3"
	},
	"pnpm": {
		"supportedArchitectures": {
			"cpu": [
				"arm64"
			],
			"os": [
				"linux",
				"darwin"
			]
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"fix:all": "biome check --write .",
		"generate-changelog": "tsx src/releases/generate-changelog.ts",
		"rc": "tsx src/releases/rc.ts",
		"rc:promote": "tsx src/releases/release.ts",
		"sync-releases": "tsx src/releases/sync-github-releases.ts"
	},
	"engines": {
		"node": ">=18"
	},
	"license": "MIT",
	"author": "Asaf Ratzon",
	"repository": {
		"type": "git",
		"url": "https://github.com/asafratzon/totopo"
	},
	"homepage": "https://github.com/asafratzon/totopo#readme",
	"keywords": [
		"ai",
		"claude",
		"docker",
		"devpod",
		"isolation",
		"security",
		"devcontainer"
	],
	"files": [
		"ai.sh",
		"src/core/",
		"templates/",
		"tsconfig.json",
		"LICENSE"
	]
}
